---

---
<section class="hero-section relative min-h-screen lg:min-h-[90vh] overflow-hidden">
  <!-- Full-bleed background image -->
  <img
    src="https://pub-d4a51ea026f44dabb421b777eebd1025.r2.dev/onbarber/hero-bg.webp"
    alt="Interior de ONBarber"
    fetchpriority="high"
    draggable="false"
    class="absolute inset-0 w-full h-full object-cover select-none"
  />

  <div class="absolute inset-0 bg-gradient-to-r from-[#0d0d0d] via-[#0d0d0d]/85 to-transparent"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-[#1a1a1a] via-transparent to-[#0d0d0d]/40"></div>

  <!-- Decorative diagonal line -->
  <div class="hidden lg:block absolute -left-20 top-0 w-px h-[140%] bg-gradient-to-b from-transparent via-brand-yellow/30 to-transparent rotate-[15deg] origin-top"></div>

  <!-- Grain texture overlay -->
  <div class="absolute inset-0 opacity-[0.035] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 128px 128px;"></div>

  <!-- Content -->
  <div class="relative z-10 min-h-screen lg:min-h-[85vh] flex items-center">
    <div class="w-full max-w-7xl mx-auto px-6 sm:px-10 md:px-16 lg:px-24">
      <div class="max-w-xl lg:max-w-2xl flex flex-col items-center text-center lg:items-start lg:text-left">

        <!-- Logo -->
        <div class="hero-fade hero-fade-1 group mb-8 lg:mb-10">
          <img
            id="hero-logo"
            src="https://pub-d4a51ea026f44dabb421b777eebd1025.r2.dev/on-logo.svg"
            alt="OnBarber"
            fetchpriority="high"
            draggable="false"
            class="select-none w-28 h-28 md:w-36 md:h-36 drop-shadow-[0_0_40px_rgba(0,0,0,0.8)] group-hover:drop-shadow-[0_0_60px_rgba(237,183,23,0.35)] group-hover:scale-105 transition-all duration-700"
          />
        </div>

        <!-- Title -->
        <h1 class="hero-fade hero-fade-2 font-bebas font-bold text-[3.5rem] leading-[0.9] sm:text-7xl md:text-8xl lg:text-[6.5rem] text-white tracking-wider mb-6">
          Tu estilo<br/>
          <span class="text-brand-yellow drop-shadow-[0_0_30px_rgba(237,183,23,0.3)]">siempre ON</span>
        </h1>

        <!-- Subtitle -->
        <p class="hero-fade hero-fade-3 text-gray-400 text-base md:text-lg max-w-md leading-relaxed mb-10 font-light">
          Barbería en Encarnación, Paraguay.<br class="hidden sm:block"/> Reservá tu turno en línea, sin esperas.
        </p>

        <!-- CTA -->
        <a href="/reservar" class="hero-fade hero-fade-3 inline-block group">
          <button class="relative bg-brand-yellow text-neutral-900 font-bold text-base md:text-lg px-10 py-4 rounded-full overflow-hidden transition-all duration-500 shadow-[0_0_25px_rgba(237,183,23,0.3)] hover:shadow-[0_0_50px_rgba(237,183,23,0.6)] hover:scale-105 active:scale-95 animate-cta-pulse">
            <span class="relative z-10 flex items-center gap-2.5">
              Reservar turno
              <svg class="w-5 h-5 transition-transform duration-500 group-hover:translate-x-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </button>
        </a>

      </div>
    </div>
  </div>

  <!-- Bottom fade into page background -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#1a1a1a] to-transparent pointer-events-none"></div>

</section>

<style>
  /* Staggered fade-in on load */
  .hero-fade {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-enter 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .hero-fade-1 { animation-delay: 0.1s; }
  .hero-fade-2 { animation-delay: 0.3s; }
  .hero-fade-3 { animation-delay: 0.5s; }
  .hero-fade-4 { animation-delay: 0.7s; }
  @keyframes hero-enter {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

</style>
