---

---
<section class="relative min-h-screen flex items-center justify-center overflow-hidden px-6 sm:px-10 md:px-16 lg:px-24 lg:py-14">
  <!-- Glow decorativo de fondo -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-yellow/[0.03] rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 flex flex-col items-center text-center gap-8 max-w-4xl">
    <!-- Logo con glow -->
    <div class="group cursor-pointer">
      <img
        src="/on-logo.svg"
        alt="OnBarber"
        fetchpriority="high"
        class="w-40 h-40 md:w-52 md:h-52 drop-shadow-[0_0_30px_rgba(0,0,0,0.6)] group-hover:drop-shadow-[0_0_50px_rgba(237,183,23,0.4)] group-hover:scale-110 group-hover:rotate-3 transition-all duration-500"
      />
    </div>



    <!-- Título -->
    <h1 class="font-bebas text-5xl font-bold md:text-7xl lg:text-8xl text-white tracking-wider leading-none">
      Tu estilo<br />siempre <span class="text-brand-yellow">ON</span>
    </h1>

    <!-- Subtítulo -->
    <p class="text-gray-400 text-base md:text-lg max-w-md leading-relaxed">
      Mensaje corto y atractivo que invite a los visitantes a reservar su turno.
    </p>

    <!-- CTA -->
    <a href="/reservar" class="mt-2 group">
      <button class="relative bg-brand-yellow text-neutral-900 font-bold text-lg md:text-xl px-12 py-5 rounded-lg overflow-hidden transition-all duration-300 shadow-[0_0_20px_rgba(237,183,23,0.25)] hover:shadow-[0_0_40px_rgba(237,183,23,0.5)] hover:scale-105 active:scale-95 animate-[cta-pulse_2.5s_ease-in-out_infinite]">
        <span class="relative z-10 flex items-center gap-2">
          Reservar turno
          <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </span>
      </button>
    </a>

    <!-- Info rápida -->
    <div class="flex items-center gap-6 mt-4 text-sm text-gray-500">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-brand-yellow" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
        Lun - Sáb
      </span>
      <span class="w-1 h-1 bg-gray-600 rounded-full"></span>
      <a href="#ubicacion" class="flex items-center gap-2 hover:text-brand-yellow transition-colors">
        <svg class="w-4 h-4 text-brand-yellow" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
        Encarnación
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <!--div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </!--div-->
</section>
