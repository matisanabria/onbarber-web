---
const R2 = 'https://pub-d4a51ea026f44dabb421b777eebd1025.r2.dev';

const services = [
  {
    name: "Corte de Cabello",
    price: "50.000 Gs",
    description: "Corte adaptado a tu estilo y tipo de cabello. Incluye asesoramiento básico.",
    images: [
      { src: `${R2}/gallery/corte1.webp`, alt: 'BuzzCut' },
      { src: `${R2}/gallery/corte2.webp`, alt: 'Taper Fade Medio' }
      //{ src: `${R2}/gallery/corte3.webp`, alt: 'Mohicano' },
    ],
  },
  {
    name: "Barba",
    price: "25.000 Gs",
    description: "Perfilado, retoque, degradado de barba, se trabaja según tu estilo y forma del rostro.",
    images: [
      { src: `${R2}/gallery/barba1.webp`, alt: 'Degradado de barba' },
      { src: `${R2}/gallery/barba2.webp`, alt: 'Perfilado de barba' },
    ],
  },
  {
    name: "Cejas",
    price: "15.000 Gs",
    description: "Perfilado de ceja para eliminar excesos, mantiene una apariencia natural y prolija.",
    images: [
      { src: `${R2}/gallery/ceja1.webp`, alt: 'Diseño de cejas' },
    ],
  },
];

const combos = [
  { name: "Corte Universitario (Lunes a Jueves)", price: "40.000 Gs", popular: true },
  { name: "Corte + Ceja",  price: "60.000 Gs", popular: false  },
  { name: "Corte + Barba", price: "70.000 Gs", popular: false  },
  {name : "Combo Completo (Corte + Barba + Ceja)", price: "80.000 Gs", popular: false },
];
---

<!-- Separador -->
<div class="w-full px-6">
  <div class="max-w-5xl mx-auto h-px bg-gradient-to-r from-transparent via-brand-yellow/20 to-transparent"></div>
</div>

<section id="servicios" class="relative px-6 py-16 md:py-20 overflow-hidden scroll-mt-20" aria-labelledby="servicios-titulo">
  <!-- Glows amarillos de fondo (solo desktop) -->
  <div class="hidden md:block absolute top-1/9 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-brand-yellow/[0.05] rounded-full blur-3xl pointer-events-none"></div>
  <div class="hidden md:block absolute top-1/5 -left-20 w-[450px] h-[450px] bg-brand-yellow/[0.06] rounded-full blur-3xl pointer-events-none"></div>
  <div class="hidden md:block absolute top-1/2 -right-20 w-[400px] h-[400px] bg-brand-yellow/[0.05] rounded-full blur-3xl pointer-events-none"></div>
  <div class="hidden md:block absolute bottom-0 left-1/3 w-[500px] h-[350px] bg-brand-yellow/[0.04] rounded-full blur-3xl pointer-events-none"></div>
  <div class="hidden md:block absolute bottom-1/4 right-1/4 w-[300px] h-[300px] bg-brand-yellow/[0.06] rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto">
    <header class="text-center mb-10 md:mb-14">
      <h2 id="servicios-titulo" class="font-bebas text-5xl font-bold md:text-5xl lg:text-6xl text-white tracking-wider leading-none">
        Nuestros <span class="text-brand-yellow">Servicios</span>
      </h2>
      <p class="mt-4 text-gray-400 text-base md:text-lg max-w-lg mx-auto leading-relaxed">
        Todo para que salgas fachero. Estamos aquí para hacerte lucir increíble.
      </p>
    </header>

    <ul class="grid grid-cols-1 md:grid-cols-3 gap-6" role="list">
      {services.map((service, idx) => (
        <li class={idx === 0 ? 'md:col-span-1 md:row-span-1 md:first:col-span-1' : ''}>
          <article class="group flex flex-col bg-neutral-900 rounded-2xl transition-all duration-500 hover:drop-shadow-[0_0_30px_rgba(237,183,23,0.15)] h-full">

            <!-- Imagen con carousel y badge de precio -->
            <div class="relative overflow-hidden rounded-t-2xl" aria-roledescription="carousel" aria-label={`Fotos de ${service.name}`}>

              <!-- Badge precio -->
              <div class="absolute top-4 right-4 z-20 bg-brand-yellow text-neutral-900 font-inter font-bold text-sm px-4 py-1.5 rounded-full shadow-lg tracking-wide">
                {service.price}
              </div>

              <div class="embla-viewport overflow-hidden" data-carousel={idx}>
                <div class="embla-container flex">
                  {service.images.map((img, i) => (
                    <div
                      class="embla-slide min-w-0 flex-[0_0_100%]"
                      role="group"
                      aria-roledescription="slide"
                      aria-label={`${i + 1} de ${service.images.length}`}
                    >
                      <div class="relative aspect-[4/3]">
                        <img
                          src={img.src}
                          alt={img.alt}
                          class="absolute inset-0 w-full h-full object-cover brightness-[0.85] contrast-[1.05]"
                          loading="lazy"
                          decoding="async"
                        />
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Gradiente inferior sobre imagen -->
              <div class="absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-neutral-900 to-transparent pointer-events-none"></div>

              <!-- Flechas -->
              <button
                class="carousel-prev absolute top-1/2 left-2 -translate-y-1/2 z-10 w-8 h-8 flex items-center justify-center rounded-full bg-black/60 text-white/80 transition-all duration-200 opacity-0 group-hover:opacity-100 hover:bg-black/80 hover:text-brand-yellow"
                aria-label="Foto anterior"
                data-prev={idx}
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                </svg>
              </button>
              <button
                class="carousel-next absolute top-1/2 right-2 -translate-y-1/2 z-10 w-8 h-8 flex items-center justify-center rounded-full bg-black/60 text-white/80 transition-all duration-200 opacity-0 group-hover:opacity-100 hover:bg-black/80 hover:text-brand-yellow"
                aria-label="Siguiente foto"
                data-next={idx}
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </button>

              <!-- Dots -->
              <div class="carousel-dots absolute bottom-3 left-1/2 -translate-x-1/2 z-10 flex gap-1.5" data-dots={idx}></div>
            </div>

            <!-- Contenido -->
            <div class="px-5 pt-4 pb-5 flex flex-col flex-1">
              <h3 class="font-bebas text-3xl text-white tracking-wider leading-tight mb-1 transition-colors duration-300 group-hover:text-brand-yellow">
                {service.name}
              </h3>
              <p class="text-gray-500/60 text-sm leading-relaxed mb-4">
                {service.description}
              </p>
              <a
                href="/reservar"
                class="mt-auto inline-flex items-center justify-center gap-2 w-full bg-brand-yellow/10 text-brand-yellow font-inter font-semibold text-sm py-2.5 rounded-lg border border-brand-yellow/20 transition-all duration-300 hover:bg-brand-yellow hover:text-neutral-900"
              >
                Reservar
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>

          </article>
        </li>
      ))}
    </ul>
    <!-- Combos -->
    <div class="mt-14">
      <div class="flex items-center gap-4 mb-6">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-brand-yellow/20 to-transparent"></div>
        <h3 class="font-bebas text-2xl md:text-3xl text-white tracking-wider">
          Combos
        </h3>
        <div class="h-px flex-1 bg-gradient-to-r from-transparent via-brand-yellow/20 to-transparent"></div>
      </div>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3" role="list">
        {combos.map((combo) => (
          <li>
            <a href="/reservar" class={`flex items-center justify-between gap-4 bg-neutral-900 rounded-xl px-6 py-5 border transition-all duration-300 group/combo h-full ${combo.popular ? 'border-brand-yellow/40 shadow-[0_0_15px_rgba(237,183,23,0.08)]' : 'border-white/5 hover:border-brand-yellow/20'}`}>
              <div class="flex items-center gap-3">
                <div class="flex flex-col">
                  <span class="font-inter font-medium text-white tracking-wide group-hover/combo:text-brand-yellow transition-colors duration-300">
                    {combo.name.replace(/\s*\(.*\)/, '')}
                  </span>
                  {combo.name.match(/\((.+)\)/) && (
                    <span class="text-xs text-gray-500 font-inter mt-0.5">
                      {combo.name.match(/\((.+)\)/)?.[1]}
                    </span>
                  )}
                </div>
                {combo.popular && (
                  <span class="text-xs font-inter font-bold uppercase tracking-widest text-neutral-900 bg-brand-yellow px-2.5 py-1 rounded-full animate-pulse">
                    Popular
                  </span>
                )}
              </div>
              <span class="font-inter font-bold text-brand-yellow shrink-0">{combo.price}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<script>
  import EmblaCarousel from 'embla-carousel';
  import Autoplay from 'embla-carousel-autoplay';

  document.querySelectorAll<HTMLElement>('.embla-viewport').forEach((viewport) => {
    const idx = viewport.dataset.carousel;
    const autoplay = Autoplay({ delay: 4000, stopOnInteraction: true });

    const embla = EmblaCarousel(viewport, {
      loop: true,
      align: 'start',
    }, [autoplay]);

    // Arrows
    const prev = document.querySelector<HTMLButtonElement>(`[data-prev="${idx}"]`);
    const next = document.querySelector<HTMLButtonElement>(`[data-next="${idx}"]`);
    prev?.addEventListener('click', () => embla.scrollPrev());
    next?.addEventListener('click', () => embla.scrollNext());

    // Dots
    const dotsContainer = document.querySelector<HTMLElement>(`[data-dots="${idx}"]`);

    function setupDots() {
      if (!dotsContainer) return;
      const scrollSnaps = embla.scrollSnapList();
      dotsContainer.innerHTML = '';
      scrollSnaps.forEach((_, i) => {
        const dot = document.createElement('button');
        dot.className = 'w-1.5 h-1.5 rounded-full bg-white/40 transition-all duration-300';
        dot.setAttribute('aria-label', `Ir a foto ${i + 1}`);
        dot.addEventListener('click', () => embla.scrollTo(i));
        dotsContainer.appendChild(dot);
      });
      updateDots();
    }

    function updateDots() {
      if (!dotsContainer) return;
      const selected = embla.selectedScrollSnap();
      dotsContainer.querySelectorAll('button').forEach((dot, i) => {
        dot.className = i === selected
          ? 'w-4 h-1.5 rounded-full bg-brand-yellow transition-all duration-300'
          : 'w-1.5 h-1.5 rounded-full bg-white/40 transition-all duration-300';
      });
    }

    embla.on('init', setupDots);
    embla.on('reInit', setupDots);
    embla.on('select', updateDots);
  });
</script>
