---

---
<footer class="bg-neutral-900/80 border-t border-gray-800">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-8">

      <!-- Logo + Copyright + Ubicación -->
      <div class="flex flex-col items-center md:items-start gap-4">
        <a href="/">
          <img src="https://pub-d4a51ea026f44dabb421b777eebd1025.r2.dev/on-isologo.svg" alt="OnBarber" class="w-44 h-auto" width="176" height="48" loading="lazy" />
        </a>
        <div class="text-center md:text-left">
          <p class="text-gray-400 text-sm leading-relaxed">
            Encarnación, Paraguay
          </p>
          <p class="text-gray-500 text-xs mt-3">
            &copy; {new Date().getFullYear()} OnBarber. Todos los derechos reservados.
          </p>
        </div>
      </div>

      <!-- Horarios -->
      <div class="flex flex-col items-center md:items-start gap-3">
        <h3 class="font-bebas text-xl tracking-wider text-white">Horarios</h3>
        <ul class="text-sm text-gray-400 space-y-2">
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-yellow shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
            <span>Lunes a Sábados: <span class="text-gray-300">9:00 – 19:00</span></span>
          </li>
          <!--li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-yellow shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
            <span>Sábados: <span class="text-gray-300">9:00 – 14:00</span></span>
          </li-->
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-600 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
            <span class="text-gray-600">Domingos: Cerrado</span>
          </li>
        </ul>
      </div>

      <!-- Ubicación -->
      <div class="flex flex-col items-center md:items-start gap-3">
        <h3 class="font-bebas text-xl tracking-wider text-white">Ubicación</h3>
        <p class="text-sm text-gray-400 text-center md:text-left">
          <svg class="w-4 h-4 text-brand-yellow inline-block mr-1 -mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
          Antequera c/ Tomás Romero Pereira, Encarnación, Paraguay
        </p>
      </div>

      <!-- Contacto -->
      <div class="flex flex-col items-center md:items-start gap-3">
