---

---
<nav class="bg-neutral-900/50 shadow-md px-4 py-3">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo -->
    <a href="/">
      <img src="/logo-on.svg" alt="Logo" class="h-13 w-13" loading="eager" />
    </a>

    <!-- Links desktop -->
    <ul class="hidden lg:flex items-center gap-10 text-sm font-medium text-gray-300">
      <li><a href="#servicios" class="flex items-center gap-1.5 hover:text-white transition-colors text-lg">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.121 14.121A3 3 0 109.88 9.88m4.242 4.242L9.88 9.879m4.242 4.242l2.829 2.829M9.879 9.879L7.05 7.05m0 0L3.172 3.172M7.05 7.05l2.829 2.83" /></svg>
        Servicios
      </a></li>
      <li><a href="#nosotros" class="flex items-center gap-1.5 hover:text-white transition-colors text-lg">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
        Nosotros
      </a></li>
      <li><a href="#contacto" class="flex items-center gap-1.5 hover:text-white transition-colors text-lg">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
        Contacto
      </a></li>
      <li><a href="#ubicacion" class="flex items-center gap-1.5 hover:text-white transition-colors text-lg">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
        Ubicación
      </a></li>
    </ul>

    <!-- Botón reservar (desktop) + hamburguesa (mobile) -->
    <div class="flex items-center gap-3">
      <a href="#reservar">
        <button class="font-bebas tracking-wider text-base px-5 py-2 rounded-lg bg-brand-yellow text-neutral-900 font-bold hover:shadow-[0_0_20px_rgba(237,183,23,0.4)] hover:scale-105 active:scale-95 transition-all duration-300">
          Reservar
        </button>
      </a>

      <!-- Hamburguesa mobile -->
      <button
        id="menu-toggle"
        class="lg:hidden p-2 text-gray-300 hover:text-white focus:outline-none"
        aria-label="Abrir menú"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h8m-8 6h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Menú mobile -->
  <div id="mobile-menu" class="hidden lg:hidden mt-3 border-t border-gray-700 pt-3">
    <ul class="flex flex-col gap-2 text-sm font-medium text-gray-300">
      <li><a href="#servicios" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-neutral-800 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.121 14.121A3 3 0 109.88 9.88m4.242 4.242L9.88 9.879m4.242 4.242l2.829 2.829M9.879 9.879L7.05 7.05m0 0L3.172 3.172M7.05 7.05l2.829 2.83" /></svg>
        Servicios
      </a></li>
      <li><a href="#nosotros" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-neutral-800 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
        Nosotros
      </a></li>
      <li><a href="#contacto" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-neutral-800 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
        Contacto
      </a></li>
      <li><a href="#ubicacion" class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-neutral-800 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
        Ubicación
      </a></li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
