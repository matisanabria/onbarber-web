---

---
<nav class="sticky top-0 z-50 bg-neutral-900/80 backdrop-blur-md shadow-md px-4 py-3">
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo -->
    <a href="/">
      <img src="https://pub-d4a51ea026f44dabb421b777eebd1025.r2.dev/on-logo.svg" alt="Logo" class="h-13 w-13" loading="eager" />
    </a>

    <!-- Links desktop -->
    <ul class="hidden lg:flex items-center gap-10 text-sm text-gray-300">
      <li><a href="/#servicios" class="group flex items-center gap-1.5 hover:text-brand-yellow transition-colors duration-300 text-lg">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>
        <span class="relative">Servicios<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-yellow transition-all duration-300 group-hover:w-full"></span></span>
      </a></li>
      <li><a href="/#nosotros" class="group flex items-center gap-1.5 hover:text-brand-yellow transition-colors duration-300 text-lg">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
        <span class="relative">Nosotros<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-yellow transition-all duration-300 group-hover:w-full"></span></span>
      </a></li>
      <li><a href="/#ubicacion" class="group flex items-center gap-1.5 hover:text-brand-yellow transition-colors duration-300 text-lg">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
        <span class="relative">Ubicación<span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-yellow transition-all duration-300 group-hover:w-full"></span></span>
      </a></li>
    </ul>

    <!-- Botón reservar (desktop) + hamburguesa (mobile) -->
    <div class="flex items-center gap-3">
      <a href="/reservar" class="hidden sm:block">
        <button class="font-inter font-bold text-sm px-5 py-2 rounded-full bg-brand-yellow text-neutral-900 hover:shadow-[0_0_20px_rgba(237,183,23,0.4)] hover:scale-105 active:scale-95 transition-all duration-300">
          Reservar
        </button>
      </a>

      <!-- Hamburguesa mobile -->
      <button
        id="menu-toggle"
        class="lg:hidden p-2 text-gray-300 hover:text-white focus:outline-none"
        aria-label="Abrir menú"
      >
        <svg id="menu-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h8m-8 6h16" />
        </svg>
        <svg id="menu-icon-close" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Menú mobile -->
  <div id="mobile-menu" class="lg:hidden mt-3 border-t border-gray-700 pt-3 grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out">
    <div class="overflow-hidden">
      <ul class="flex flex-col gap-1 text-sm font-medium text-gray-300 pb-2">
        <li><a href="/#servicios" class="flex items-center gap-2 px-3 py-2.5 rounded-lg hover:bg-neutral-800 hover:text-brand-yellow transition-colors duration-300">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>
          Servicios
        </a></li>
        <li><a href="/#nosotros" class="flex items-center gap-2 px-3 py-2.5 rounded-lg hover:bg-neutral-800 hover:text-brand-yellow transition-colors duration-300">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
          Nosotros
        </a></li>
        <li><a href="/#ubicacion" class="flex items-center gap-2 px-3 py-2.5 rounded-lg hover:bg-neutral-800 hover:text-brand-yellow transition-colors duration-300">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
          Ubicación
        </a></li>
        <li class="mt-1 px-3">
          <a href="/reservar" class="flex items-center justify-center gap-2 w-full py-2.5 rounded-full bg-brand-yellow text-neutral-900 font-inter font-bold text-sm hover:shadow-[0_0_20px_rgba(237,183,23,0.4)] transition-all duration-300">
            Reservar turno
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  let isOpen = false;

  toggle?.addEventListener('click', () => {
    isOpen = !isOpen;
    if (isOpen) {
      menu?.classList.remove('grid-rows-[0fr]');
      menu?.classList.add('grid-rows-[1fr]');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
    } else {
      menu?.classList.remove('grid-rows-[1fr]');
      menu?.classList.add('grid-rows-[0fr]');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    }
  });

  // Cerrar menú al hacer click en un link
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      isOpen = false;
      menu?.classList.remove('grid-rows-[1fr]');
      menu?.classList.add('grid-rows-[0fr]');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
