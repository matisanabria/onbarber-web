---
const mapsUrl = "https://www.google.com/maps/place/ON.Barber/@-27.3320252,-55.8717119,18z/data=!4m6!3m5!1s0x945795a02d523f87:0xc882fdebf3d43038!8m2!3d-27.3318913!4d-55.8711766!16s%2Fg%2F11vbwppp6h";
---

<!-- Separador -->
<div class="w-full px-6">
  <div class="max-w-5xl mx-auto h-px bg-gradient-to-r from-transparent via-brand-yellow/20 to-transparent"></div>
</div>

<section id="ubicacion" class="relative px-6 py-16 md:py-24 overflow-hidden scroll-mt-20" aria-labelledby="ubicacion-titulo">

  <!-- Background sutil -->
  <div class="absolute inset-0 bg-neutral-900/40 pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/4 -translate-y-1/2 w-[500px] h-[500px] bg-brand-yellow/[0.04] rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

    <!-- Texto -->
    <div class="flex flex-col gap-6 text-center lg:text-left items-center lg:items-start">
      <header>
        <h2 id="ubicacion-titulo" class="font-bebas font-bold text-4xl md:text-5xl text-white tracking-wider leading-none">
          Dónde <span class="text-brand-yellow">encontrarnos</span>
        </h2>
        <p class="mt-4 text-gray-400 text-base md:text-lg leading-relaxed">
          Estamos en el centro de Encarnación, a menos de media cuadra de la Universidad Católica. Pasá cuando quieras o reservá tu turno online.
        </p>
      </header>

      <!-- Info -->
      <div class="flex flex-col gap-4">
        <!-- Dirección -->
        <div class="flex items-start gap-3">
          <span class="mt-0.5 shrink-0 text-brand-yellow">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
            </svg>
          </span>
          <div>
            <p class="text-white font-medium">Antequera c/ Tomás Romero Pereira</p>
            <p class="text-gray-400 text-sm">Encarnación, Paraguay</p>
          </div>
        </div>

        <!-- Horario -->
        <div class="flex items-start gap-3">
          <span class="mt-0.5 shrink-0 text-brand-yellow">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
          </span>
          <div>
            <p class="text-white font-medium">Lunes a Sábado</p>
            <p class="text-gray-400 text-sm">Reservas online disponibles</p>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <a
        href={mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 bg-white/5 text-gray-300 border border-white/10 font-inter font-medium text-sm px-6 py-3 rounded-full hover:bg-white/10 hover:text-white transition-all duration-300"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
        Abrir en Google Maps
      </a>
    </div>

    <!-- Mapa -->
    <a
      href={mapsUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Ver OnBarber en Google Maps"
      class="group relative block rounded-lg overflow-hidden border border-white/5 shadow-[0_0_40px_rgba(0,0,0,0.4)] aspect-video lg:aspect-auto lg:h-80"
    >
      <img
        src="https://pub-d4a51ea026f44dabb421b777eebd1025.r2.dev/map.webp"
        alt="Mapa de ubicación de OnBarber en Encarnación"
        class="w-full h-full object-cover"
        loading="lazy"
        width="1200"
        height="600"
      />
      <!-- Overlay hover -->
      <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
        <span class="opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-neutral-900/80 text-brand-yellow text-sm font-medium px-4 py-2 rounded-lg flex items-center gap-2">
          Abrir en Google Maps
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </span>
      </div>
    </a>

  </div>
</section>
