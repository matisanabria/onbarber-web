---

---

<!-- Separador -->
<div class="w-full px-6">
  <div class="max-w-5xl mx-auto h-px bg-gradient-to-r from-transparent via-brand-yellow/20 to-transparent"></div>
</div>

<section id="nosotros" class="relative px-6 py-16 md:py-24 overflow-hidden scroll-mt-20" aria-labelledby="nosotros-titulo">

  <!-- Background sutil -->
  <div class="absolute inset-0 bg-neutral-900/40 pointer-events-none"></div>
  <div class="absolute top-1/3 right-1/4 w-[500px] h-[500px] bg-brand-yellow/[0.04] rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

    <!-- Imagen -->
    <div class="relative rounded-2xl overflow-hidden border border-white/5 shadow-[0_0_40px_rgba(0,0,0,0.4)] group">
      <img
        src="https://pub-d4a51ea026f44dabb421b777eebd1025.r2.dev/barber.webp"
        alt="OnBarber barbería en Encarnación"
        width="1280"
        height="720"
        loading="lazy"
        decoding="async"
        class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
      />
      <!-- Label sobre la imagen -->
      <div class="absolute bottom-4 left-4 bg-neutral-900/80 backdrop-blur-sm text-white text-xs font-inter font-medium px-3 py-1.5 rounded-full border border-white/10">
        Nuestro local en Encarnación
      </div>
    </div>

    <!-- Texto -->
    <div class="flex flex-col gap-6 text-center lg:text-left">
      <header>
        <h2 id="nosotros-titulo" class="font-bebas font-bold text-5xl md:text-5xl lg:text-6xl text-white tracking-wider leading-none">
          Sobre <span class="text-brand-yellow">nosotros</span>
        </h2>
        <p class="mt-4 text-gray-400 text-base md:text-lg leading-relaxed">
          Somos una barbería hecha por barberos que aman lo que hacen. Acá vas a encontrar buen ambiente, buena música y gente que realmente disfruta su trabajo.
        </p>
        <p class="mt-3 text-gray-400 text-base md:text-lg leading-relaxed">
          Cada corte es personalizado — nos tomamos el tiempo de entender tu estilo y la forma de tu rostro para que salgas siempre conforme.
        </p>
      </header>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center lg:justify-start">
        <a
          href="/reservar"
          class="inline-flex items-center justify-center gap-2 bg-brand-yellow text-neutral-900 font-inter font-bold text-sm px-6 py-3 rounded-full hover:shadow-[0_0_20px_rgba(237,183,23,0.4)] hover:scale-105 active:scale-95 transition-all duration-300"
        >
          Reservar turno
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <a
          href="/#ubicacion"
          class="inline-flex items-center justify-center gap-2 bg-white/5 text-gray-300 border border-white/10 font-inter font-medium text-sm px-6 py-3 rounded-full hover:bg-white/10 hover:text-white transition-all duration-300"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
          Ver ubicación
        </a>
        <!-- TODO: habilitar cuando estén los datos de los barberos -->
        <span
          class="inline-flex items-center justify-center gap-2 bg-white/5 text-gray-500 border border-white/5 font-inter font-medium text-sm px-6 py-3 rounded-full cursor-not-allowed opacity-50"
          aria-disabled="true"
          title="Próximamente"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
          Conocé a los barberos
        </span>
      </div>
    </div>

  </div>
</section>
