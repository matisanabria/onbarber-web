---
	import "../assets/app.css";
	import Header from '../components/Header.astro'
	import Footer from '../components/Footer.astro'
---

<!doctype html>
<html lang="es">
	<head>

		<meta charset="UTF-8" />

		<meta name="viewport" content="width=device-width" />

		<title>ONBarber - Barbería en Encarnación, Paraguay</title>

		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://pub-d4a51ea026f44dabb421b777eebd1025.r2.dev" crossorigin />
		<link rel="preload" href="https://pub-d4a51ea026f44dabb421b777eebd1025.r2.dev/on-logo.svg" as="image" fetchpriority="high" />
		<link rel="preload" href="/fonts/BebasNeueBold.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/Inter-Regular.woff2" as="font" type="font/woff2" crossorigin />

		<meta name="description" content="ONBarber es una barbería ubicada en Encarnación, Paraguay, 
		que ofrece servicios de corte de cabello, barba, para hombres. 
		Cuenta con barberos profesionales que se dedican a brindar un servicio de alta calidad en un ambiente acogedor y moderno." />

		<meta property="og:title" content="ONBarber - Barbería en Encarnación, Paraguay" />
		<meta property="og:description" content="ONBarber es una barbería ubicada en Encarnación, Paraguay, 
		que ofrece servicios de corte de cabello, barba, para hombres. 
		Cuenta con barberos profesionales que se dedican a brindar un servicio de alta calidad en un ambiente acogedor y moderno." />
		<meta property="og:image" content="https://pub-d4a51ea026f44dabb421b777eebd1025.r2.dev/og-image.webp" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="es_PY" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:image" content="https://pub-d4a51ea026f44dabb421b777eebd1025.r2.dev/og-image.webp" />
		<meta name="twitter:title" content="ONBarber - Barbería en Encarnación, Paraguay" />
	</head>

	<body>
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[100] focus:bg-brand-yellow focus:text-neutral-900 focus:px-4 focus:py-2 focus:rounded-lg">Saltar al contenido</a>
		<Header />
		<main id="main-content">
			<slot />
		</main>
		<Footer />
	
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
</style>
